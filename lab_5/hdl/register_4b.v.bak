module register_4b (
    input reg [3:0] in,
    input reg clk,
    input reg reset,
    input reg enable,
    output reg [3:0] out
);

    always @(posedge clk or posedge reset) begin
        if (reset) begin 
            out <= 4'b0000;
        end else if (enable) begin
            out <= data_in;
        end else begin
            out <= out;
        end 
    end

endmodule