module carrylookahead4bit(
    input wire [3:0] a,
    input wire [3:0] b,
    input wire cin,
    output wire [3:0] sum,
    output wire cout
);
wire [3:0] wc, wp, wg;
assign wg = a & b;
assign wp = a + b;

assign wc[0] = cin;
assign wc[1] = wg[0] | (wp[0] & wc[0]);
assign wc[2] = wg[1] | (wp[1] & wc[1]);
assign wc[3] = wg[2] | (wp[2] & wc[2]);
assign cout = wg[3] | (wp[3] & wc[3]);

fulladder adder0(
    .a(a[0]),
    .b(b[0]),
    .cin(wc[0]),
    .sum(sum[0]),
    .cout(0)
);

fulladder adder1(
    .a(a[1]),
    .b(b[1]),
    .cin(wc[1]),
    .sum(sum[1]),
    .cout(0)
);

fulladder adder2(
    .a(a[2]),
    .b(b[2]),
    .cin(wc[2]),
    .sum(sum[2]),
    .cout(0)
);

fulladder adder3(
    .a(a[3]),
    .b(b[3]),
    .cin(wc[3]),
    .sum(sum[3]),
    .cout(cout)
);

endmodule